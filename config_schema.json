{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chamber Configuration",
  "description": "Configuration for deploying a Cadence Managed Cloud chamber based on SOW requirements",
  "type": "object",
  "required": [
    "platform_provider",
    "chamber_location",
    "total_users",
    "user_accounts",
    "hardware",
    "software_licenses"
  ],
  "properties": {
    "customer_name": {
      "type": "string",
      "description": "Name of the customer (redacted if sensitive)"
    },
    "platform_provider": {
      "type": "string",
      "enum": ["AWS", "GCP", "Azure"],
      "description": "Cloud provider for the chamber"
    },
    "chamber_location": {
      "type": "string",
      "description": "Region or location for the chamber (e.g., AWS Frankfurt)"
    },
    "third_party_licence_chamber_required": {
      "type": "boolean",
      "description": "Whether a 3rd party licence chamber is required"
    },
    "total_users": {
      "type": "integer",
      "minimum": 1,
      "description": "Total number of users across all locations"
    },
    "user_accounts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["count", "location"],
        "properties": {
          "count": {
            "type": "integer",
            "minimum": 1
          },
          "location": {
            "type": "string"
          }
        }
      },
      "description": "User accounts broken down by location"
    },
    "hardware": {
      "type": "object",
      "required": ["interactive_servers"],
      "properties": {
        "interactive_servers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["count", "instance_type", "vcpus", "memory_gb"],
            "properties": {
              "count": { "type": "integer", "minimum": 1 },
              "purpose": { "type": "string" },
              "instance_type": { "type": "string", "description": "e.g., M6i.4xlarge" },
              "vcpus": { "type": "integer", "minimum": 1 },
              "memory_gb": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "storage": {
          "type": "object",
          "properties": {
            "backup_storage_gb": { "type": "integer", "minimum": 0 },
            "scratch_storage_gb": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "software_licenses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["product_name", "quantity"],
        "properties": {
          "product_name": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 }
        }
      },
      "description": "List of Cadence products/tools with license counts"
    },
    "additional_services": {
      "type": "object",
      "properties": {
        "pdks_to_install": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "source": { "type": "string", "enum": ["customer_provided", "cadence_provided"] }
            }
          }
        }
      }
    }
  }
}
