{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Auto-Generated Chamber Configuration Schema",
  "description": "Generated from 3 example config files",
  "type": "object",
  "required": [
    "backup_enabled",
    "compute",
    "customer_name",
    "environment_tier",
    "estimated_users",
    "high_availability",
    "networking",
    "services",
    "storage"
  ],
  "properties": {
    "customer_name": {
      "type": "string",
      "description": "Observed values: ['Acme Corporation', 'BrightStar Analytics', 'GreenLeaf Health Systems']"
    },
    "environment_tier": {
      "type": "string",
      "description": "Observed values: ['enterprise', 'large', 'medium']"
    },
    "compute": {
      "type": "object",
      "properties": {
        "instance_count": {
          "type": "integer",
          "_observed_min": 2,
          "_observed_max": 6
        },
        "instance_type": {
          "type": "string",
          "_observed_values": [
            "n2-standard-4",
            "n2-standard-8"
          ]
        },
        "memory_gb_per_instance": {
          "type": "integer",
          "_observed_min": 16,
          "_observed_max": 32
        },
        "vcpus_per_instance": {
          "type": "integer",
          "_observed_min": 4,
          "_observed_max": 8
        }
      },
      "required": [
        "instance_count",
        "instance_type",
        "memory_gb_per_instance",
        "vcpus_per_instance"
      ]
    },
    "storage": {
      "type": "object",
      "properties": {
        "iops_required": {
          "type": "integer",
          "_observed_min": 1500,
          "_observed_max": 10000
        },
        "storage_type": {
          "type": "string",
          "_observed_values": [
            "pd-ssd",
            "pd-standard"
          ]
        },
        "total_storage_gb": {
          "type": "integer",
          "_observed_min": 500,
          "_observed_max": 5000
        }
      },
      "required": [
        "iops_required",
        "storage_type",
        "total_storage_gb"
      ]
    },
    "networking": {
      "type": "object",
      "properties": {
        "load_balancer": {
          "type": "boolean"
        },
        "subnet_count": {
          "type": "integer",
          "_observed_min": 2,
          "_observed_max": 4
        },
        "vpc_cidr": {
          "type": "string",
          "_observed_values": [
            "10.1.0.0/16",
            "10.10.0.0/16",
            "10.2.0.0/16"
          ]
        }
      },
      "required": [
        "load_balancer",
        "subnet_count",
        "vpc_cidr"
      ]
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "configuration": {
            "type": "object"
          },
          "enabled": {
            "type": "boolean"
          },
          "service_name": {
            "type": "string",
            "_observed_values": [
              "BigQuery",
              "Cloud Armor",
              "Cloud KMS",
              "Cloud Logging",
              "Cloud Monitoring",
              "Cloud SQL",
              "Cloud Storage",
              "Dataflow"
            ]
          }
        },
        "required": [
          "configuration",
          "enabled",
          "service_name"
        ]
      }
    },
    "high_availability": {
      "type": "boolean"
    },
    "backup_enabled": {
      "type": "boolean"
    },
    "estimated_users": {
      "type": "integer",
      "minimum": 50
    }
  }
}