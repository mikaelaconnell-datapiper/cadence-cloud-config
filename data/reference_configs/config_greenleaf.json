{
  "customer_name": "GreenLeaf Health Systems",
  "environment_tier": "enterprise",
  "compute": {
    "instance_type": "n2-standard-8",
    "instance_count": 6,
    "vcpus_per_instance": 8,
    "memory_gb_per_instance": 32
  },
  "storage": {
    "storage_type": "pd-ssd",
    "total_storage_gb": 5000,
    "iops_required": 10000
  },
  "networking": {
    "vpc_cidr": "10.10.0.0/16",
    "subnet_count": 4,
    "load_balancer": true
  },
  "services": [
    {
      "service_name": "Cloud SQL",
      "enabled": true,
      "configuration": {
        "engine": "MySQL",
        "tier": "db-highmem-8"
      }
    },
    {
      "service_name": "Cloud Storage",
      "enabled": true,
      "configuration": {
        "bucket_class": "standard"
      }
    },
    {
      "service_name": "Cloud Monitoring",
      "enabled": true,
      "configuration": {}
    },
    {
      "service_name": "Cloud Logging",
      "enabled": true,
      "configuration": {
        "audit_logging": true
      }
    },
    {
      "service_name": "Cloud KMS",
      "enabled": true,
      "configuration": {}
    },
    {
      "service_name": "Cloud Armor",
      "enabled": true,
      "configuration": {}
    }
  ],
  "high_availability": true,
  "backup_enabled": true,
  "estimated_users": 1000
}
